{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "main",
  "compilerOptions": {
    "plugins": ["@nestjs/swagger/plugin"],
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      {
        "include": "assets/**/*",
        "outDir": "dist/assets"
      },
      {
        "include": "prisma/**/*",
        "outDir": "dist/prisma"
      }
    ]
  }
}
