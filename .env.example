# NEVERFLAT Award Core Configuration

# Treasury Wallet Configuration
# The Polygon address of the treasury wallet that holds SPARKZ tokens
# This wallet will be used to sign award transactions
TREASURY_ADDRESS=0x3c67B7754EEAe43BAEc8ab82E8Dfc793B8A90C41

# Treasury signer private key (for production signing)
# Should be stored securely in a key management system
# You can set the private key directly or use a mounted secret file.
# TREASURY_SIGNER_KEY=
# TREASURY_SIGNER_KEY_FILE=/run/secrets/treasury_signer_key

# User Address Derivation
# Salt used for deterministic address generation from UIDs
# Changing this value will change all derived addresses (use with caution)
USER_ADDRESS_DERIVATION_SALT=nvf-award-core-v1

# PostgreSQL Database
# Connection string for the database that mirrors blockchain state
# Format: postgres://user:password@host:port/database
# Leave blank to run without database (awards/spends will still work on-chain)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nvf_award

# PostgreSQL Docker settings
POSTGRES_DB=nvf_award
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API Server
# Port for REST API server
PORT=3000

# CORS allowed origin for browser-based frontend apps
# Use * for demo/testing, or set to a specific origin such as http://localhost:3001
CORS_ORIGIN=*

# RPC Configuration (if running locally)
# POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/


