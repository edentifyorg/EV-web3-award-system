{
  "name": "nvf-award-core",
  "version": "1.0.0",
  "description": "NEVERFLAT Award Core Backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "api": "tsc && node dist/api.js",
    "db:migrate": "tsc && node dist/database/migrate.js",
    "db:reset": "tsc && npm run db:migrate",
    "ci:check": "npm audit --audit-level=moderate && npm run build && npm test && npm --prefix frontend audit --audit-level=moderate && npm --prefix frontend run build"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "ethers": "^6.0.0",
    "express": "^4.18.0",
    "knex": "^3.0.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/src/**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/dist/"
    ]
  }
}
